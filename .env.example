ZOHO_CLIENT_SECRET=3eca0125462d80fe301bfec431ba169daca578894c
ZOHO_REFRESH_TOKEN=1000.28f8d2bb757e865f48504c7e3b57a1ae.ffc8d77d2bdf752e6c369ecf68f27345

# Optional: use a static access token to avoid refresh (e.g. when rate-limited). Token expires in ~1 hour.
# ZOHO_ACCESS_TOKEN=1000.xxxx
# If unset, access token is refreshed from refresh token (hourly via cron) and persisted to .zoho-token.json when writable.

# Cron: set CRON_SECRET and send header x-cron-secret when calling /api/cron/refresh-token (e.g. external cron every hour).
# CRON_SECRET=your-secret

# Optional: if your Zoho account is not on India DC, set domain and Creator API base:
# ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com
# ZOHO_CREATOR_BASE=https://www.zohoapis.com/creator/v2.1/data

# Door Core quotation (idealfitout app) - report can be Quotation_Log_Door_Core or Core_Cover_page_Report
# ZOHO_ACCOUNT_OWNER=idealfitsout
# ZOHO_APP_LINK_NAME=idealfitout
# ZOHO_REPORT_LINK_NAME=Quotation_Log_Door_Core
# (Or set to Core_Cover_page_Report; URL ?report=... overrides this for the request)